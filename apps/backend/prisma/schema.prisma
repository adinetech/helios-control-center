generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  OPERATOR
}

enum FarmStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  WARNING
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farms     Farm[]   @relation("UserFarms")
  tasks     Task[]   @relation("UserTasks")
}

model Farm {
  id          String   @id @default(uuid())
  name        String
  location    String
  capacityKw  Float
  status      FarmStatus @default(OFFLINE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserFarms")
  telemetry   Telemetry[]
  tasks       Task[]   @relation("FarmTasks")
}

model Telemetry {
  id            String   @id @default(uuid())
  farmId        String
  farm          Farm     @relation(fields: [farmId], references: [id])
  timestamp     DateTime @default(now())
  powerOutputKw Float
  temperatureC  Float
  irradiance    Float

  // Extended Hybrid Inverter Metrics
  pv1PowerKw         Float?
  pv2PowerKw         Float?
  totalPvPowerKw     Float?
  batterySoc         Float?
  batteryVoltage     Float?
  batteryPowerKw     Float?
  gridPowerKw        Float?
  loadPowerKw        Float?
  dailyProductionKwh Float?
  totalProductionKwh Float?
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  farmId      String?
  assigneeId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  farm        Farm?        @relation("FarmTasks", fields: [farmId], references: [id])
  assignee    User?        @relation("UserTasks", fields: [assigneeId], references: [id])
}
