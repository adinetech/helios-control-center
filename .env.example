# Helios Control Center - Environment Configuration Example

# Backend Database Connection
# Replace "admin" and "password" with your secure credentials in production
DATABASE_URL="postgresql://admin:password@database:5432/helios?schema=public"

# JWT Secret Key
# Generate a secure 256-bit secret for production (e.g., using `openssl rand -hex 32`)
JWT_SECRET="super-secret-development-key-change-me"

# Frontend Configuration
# Define the Backend API endpoint
VITE_API_URL="http://localhost:3000"

# Grafana# Monitoring Stack
GF_SECURITY_ADMIN_PASSWORD=admin
# TELEMETRY_PROVIDER=simulator
# DEYE_EXPORTER_URL=http://100.x.x.x:9105/metrics
GF_AUTH_ANONYMOUS_ENABLED="true"
GF_AUTH_ANONYMOUS_ORG_ROLE="Admin"

TELEMETRY_PROVIDER=deye
DEYE_EXPORTER_URL=http://192.168.0.8:9105/metrics